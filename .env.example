# Sentry — browser (public, set in Vercel env)
NEXT_PUBLIC_SENTRY_DSN=
# Sentry — server/edge (private, set in Vercel env)
SENTRY_DSN=
# Sentry source map upload (set in Vercel env)
SENTRY_AUTH_TOKEN=
# App environment tag (development | staging | production)
NEXT_PUBLIC_ENV=development
# Git SHA for Sentry release tracking (injected by CI/Vercel)
NEXT_PUBLIC_GIT_SHA=
